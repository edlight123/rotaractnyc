# =============================================
# Rotaract NYC — Environment Variables
# =============================================
# Copy this file to .env.local and fill in the values.

# ---- Firebase Client SDK ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=rotaractnyc-ac453.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=rotaractnyc-ac453
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=rotaractnyc-ac453.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin SDK ----
FIREBASE_PROJECT_ID=rotaractnyc-ac453
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- Resend (Email) ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@rotaractnyc.org

# ---- Site URL (used for Stripe redirect URLs, etc.) ----
NEXT_PUBLIC_SITE_URL=https://rotaractnyc.org

# ---- Google Cloud Vision API (optional — for auto-tagging imported photos) ----
# Get a key at https://console.cloud.google.com/apis/library/vision.googleapis.com
# Free tier: 1,000 label detections/month
GOOGLE_CLOUD_VISION_API_KEY=

# ---- Google Workspace (optional — Calendar / Sheets / Drive integration) ----
# Full JSON of the service-account key, as a single-line string.
GOOGLE_SERVICE_ACCOUNT_KEY=

# ---- Google Workspace user provisioning (optional) ----
# Auto-create @domain member accounts from the portal. Requires a paid/nonprofit
# Workspace, the Admin SDK API enabled, and the service account authorized for the
# admin.directory.user scope under Admin console → Security → API Controls →
# Domain-wide Delegation. The credential reuses FIREBASE_SERVICE_ACCOUNT by
# default (same GCP project), so you usually only need the two vars below.
# GOOGLE_WORKSPACE_ADMIN_EMAIL must be the PRIMARY email of a real super-admin.
#
# DWD scopes to authorize for the service account (Client ID 105377899018085415134):
#   https://www.googleapis.com/auth/admin.directory.user          (member org emails)
#   https://www.googleapis.com/auth/admin.directory.group         (committee group emails)
#   https://www.googleapis.com/auth/admin.directory.group.member  (committee group members)
# The group scopes are only needed for the "Committee group emails" feature; user
# provisioning works with just the directory.user scope. Each scope is independent —
# adding the group scopes will not affect existing user provisioning.
GOOGLE_WORKSPACE_DOMAIN=rotaractnyc.org
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@rotaractnyc.org

# ---- Slack (optional — included in new-member onboarding email) ----
# A shared "Join Slack" invite link (Slack admin → Invite people → shareable link).
SLACK_INVITE_URL=

